#!/usr/bin/env bash

# Resize all panes to equal width, respecting bottom pane if it exists

# Get all panes with their info
panes_data=$(tmux list-panes -F '#{pane_id}|#{pane_top}|#{pane_height}|#{pane_index}')
window_height=$(tmux display-message -p '#{window_height}')

# Parse panes and identify layout structure
declare -a side_panes
bottom_pane=""
bottom_pane_height=0

while IFS='|' read -r pane_id pane_top pane_height pane_index; do
    pane_bottom=$((pane_top + pane_height))

    # Bottom pane: reaches window bottom and doesn't start at top
    if [ "$pane_bottom" -eq "$window_height" ] && [ "$pane_top" -gt 0 ]; then
        bottom_pane="$pane_id"
        bottom_pane_height="$pane_height"
    else
        side_panes+=("$pane_id")
    fi
done <<< "$panes_data"

num_side_panes=${#side_panes[@]}

# Exit if nothing to balance
if [ "$num_side_panes" -le 1 ] && [ -z "$bottom_pane" ]; then
    exit 0
fi

# If there's a bottom pane, temporarily remove it, resize, then restore
if [ -n "$bottom_pane" ]; then
    # Select the bottom pane and break it into a new window
    tmux select-pane -t "$bottom_pane"
    tmux break-pane -d

    # Resize the remaining side panes equally
    tmux select-layout even-horizontal

    # Bring back the bottom pane
    tmux join-pane -v -l "$bottom_pane_height"
else
    # No bottom pane, just resize all panes equally
    tmux select-layout even-horizontal
fi
